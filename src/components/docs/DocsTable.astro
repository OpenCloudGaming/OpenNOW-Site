---
interface DocsTableColumn {
  key: string;
  header: string;
  code?: boolean;
  fallbackKey?: string;
}

type DocsTableRow = Record<string, string | undefined>;

interface Props {
  columns: DocsTableColumn[];
  rows: DocsTableRow[];
}

const { columns, rows } = Astro.props as Props;

const escapeHtml = (value: string) =>
  value
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');

const formatInline = (value: string | undefined, code = false) => {
  if (!value) return '';
  const formattedValue = code ? `\`${value}\`` : value;
  return escapeHtml(formattedValue).replace(/`([^`]+)`/g, '<code>$1</code>');
};

const getValue = (row: DocsTableRow, column: DocsTableColumn) =>
  row[column.key] ?? (column.fallbackKey ? row[column.fallbackKey] : undefined);
---

<table>
  <thead>
    <tr>
      {columns.map((column) => <th>{column.header}</th>)}
    </tr>
  </thead>
  <tbody>
    {
      rows.map((row) => (
        <tr>
          {columns.map((column) => <td set:html={formatInline(getValue(row, column), column.code)} />)}
        </tr>
      ))
    }
  </tbody>
</table>
